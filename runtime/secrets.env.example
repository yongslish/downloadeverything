# Copy this file to runtime/secrets.env, then fill in your own values.
# Do not commit or share runtime/secrets.env.

# 讯飞「录音文件转写大模型」
XUNFEI_LLM_ASR_APP_ID=
XUNFEI_LLM_ASR_API_KEY=
XUNFEI_LLM_ASR_API_SECRET=

# 讯飞「录音文件转写标准版」（可选）
XUNFEI_LFASR_APP_ID=
XUNFEI_LFASR_SECRET_KEY=

# DeepSeek（学习笔记 LLM 合成）
DEEPSEEK_API_KEY=

# 本地 FunASR（无需密钥；通常不需要修改）
